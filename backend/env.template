# Copiar a .env y ajustar valores (no commitear .env)

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=pokemon_app

# TypeORM: true en desarrollo; false en producción (usar migraciones)
DB_SYNC=true
# Logs SQL: true | false
DB_LOGGING=false

# JWT (obligatorio tener secret fuerte en producción)
JWT_SECRET=puedes-cambiar-esto-luego
JWT_EXPIRES=7d

# API
PORT=3000
CORS_ORIGIN=http://localhost:5173
